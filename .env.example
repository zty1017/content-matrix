# 应用基础配置
APP_NAME=Content Matrix
APP_VERSION=0.0.1
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

# CORS 来源，多个值用英文逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# LLM 提供方配置；v0 默认使用离线 mock 模式
LLM_PROVIDER=mock
LLM_MODEL=mock-content-matrix-v0
LLM_MOCK_MODE=true

# 真实提供方密钥占位；mock 模式下可以留空
OPENAI_API_KEY=
DOUBAO_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# mock 响应延迟，单位毫秒
MOCK_RESPONSE_DELAY_MS=0
